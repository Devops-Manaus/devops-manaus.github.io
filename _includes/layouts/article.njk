---
layout: layouts/base.njk
---

<article style="max-width: 760px; margin: 0 auto; padding: 6rem 1.5rem 4rem;">
  {% if image %}
    <img src="{{ image }}" alt="{{ title }}" style="width: 100%; height: auto; border-radius: 12px; margin-bottom: 2rem; object-fit: cover; max-height: 420px;">
  {% endif %}

  <header style="margin-bottom: 2rem;">
    <h1 style="font-size: 2.25rem; line-height: 1.2; margin: 0 0 .75rem;">{{ title }}</h1>
    {% if date %}
      <time style="color: #807a6d; font-size: .9rem;">{{ date }}</time>
    {% endif %}
  </header>

  <div class="article-body" style="font-size: 1.05rem; line-height: 1.7; color: #15130f;">
    {{ content | safe }}
  </div>

  <p style="margin-top: 3rem;">
    <a href="/articles/" style="color: oklch(52% 0.09 175);">← Voltar aos artigos</a>
  </p>
</article>

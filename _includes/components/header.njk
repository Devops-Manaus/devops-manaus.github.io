<header class="site-header">
  <div class="site-header__inner">

    <div class="site-header__left">
      <a href="/" class="site-header__brand">
        <svg width="26" height="26" viewBox="0 0 26 26" aria-hidden="true">
          <circle cx="10" cy="13" r="8" fill="var(--accent)" />
          <circle cx="16" cy="13" r="8" fill="var(--accent-2)" style="mix-blend-mode: multiply; opacity: 0.88;" />
        </svg>
        <span>
          DevOps<span> / Manaus</span>
        </span>
      </a>

      <nav class="site-header__nav" aria-label="Navegação principal">
        {% for item in navlinks %}
        <a href="{{ item.href }}">
          {{ item.label }}
        </a>
        {% endfor %}
      </nav>
    </div>

    <details class="mobile-menu">
      <summary aria-label="Abrir menu">
        <span></span>
        <span></span>
        <span></span>
      </summary>

      <div class="mobile-menu__panel">
        <nav class="mobile-menu__nav" aria-label="Navegação mobile">
          {% for item in navlinks %}
          <a href="{{ item.href }}">{{ item.label }}</a>
          {% endfor %}
        </nav>

      </div>
    </details>

  </div>
</header>

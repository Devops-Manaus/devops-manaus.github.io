<section id="about" class="content-section about">

  <div class="section-heading">
    <p>De Manaus para a comunidade</p>
    <h2>Conheça nossa história</h2>
  </div>

  <div class="about__list">
    {% for item in search.pages("type=about", "order=asc") %}
    <article class="about__item">
      <span>0{{ loop.index }}</span>
      <div><h3>{{ item.heading }}</h3><p>{{ item.text }}</p></div>
    </article>
    {% endfor %}
  </div>

</section>

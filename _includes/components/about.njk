<section id="about" style="max-width: 1200px; margin: 0 auto; padding: 70px 28px;">

  <h2 style="font-size: 42px; margin: 0 0 60px 0; font-weight: 600; letter-spacing: -1px;">
    Conheça nossa história
  </h2>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 32px;">
    {% for item in search.pages("type=about", "order=asc") %}
    <div style="padding: 28px; background: var(--bg-card); border: 1px solid var(--line); border-radius: 12px;">
      <h3 style="font-size: 20px; margin: 0 0 14px 0; font-weight: 600; letter-spacing: -0.3px;">
        {{ item.heading }}
      </h3>
      <p style="font-size: 14px; color: var(--ink-2); line-height: 1.6; margin: 0;">
        {{ item.text }}
      </p>
    </div>
    {% endfor %}
  </div>

</section>

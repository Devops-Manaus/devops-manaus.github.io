<footer class="site-footer">
  <div class="site-footer__grid">

    <!-- Brand section -->
    <div class="site-footer__brand">
      <div>
        <svg width="26" height="26" viewBox="0 0 26 26">
          <circle cx="10" cy="13" r="8" fill="var(--accent)" />
          <circle cx="16" cy="13" r="8" fill="var(--accent-2)" style="mix-blend-mode: multiply; opacity: 0.88;" />
        </svg>
        <span>DevOps / Manaus</span>
      </div>
      <p>
        Comunidade aberta de profissionais de infraestrutura, plataforma e cultura DevOps em Manaus e no interior do Amazonas. Feito por voluntários, desde 2021.
      </p>
    </div>

    <!-- Links -->
    <div class="site-footer__links">
      <div class="mono">
        Comunidade
      </div>
      <ul>
        <li><a href="#about">Sobre</a>
        </li>
        <li><a href="#">Código de conduta</a>
        </li>
        <li><a href="#organizers">Organizadores</a>
        </li>
      </ul>
    </div>

    <!-- More links -->
    <div class="site-footer__links">
      <div class="mono">
        Aprender
      </div>
      <ul>
        <li><a href="https://linuxtips.io" target="_blank" rel="noopener noreferrer">Trilhas</a>
        </li>
        <li><a href="/articles/">Blog</a>
        </li>
      </ul>
    </div>

    <!-- Social -->
    <div class="site-footer__links">
      <div class="mono">
        Conectar
      </div>
      {% if footer and footer.social %}
      <div class="site-footer__socials">
        {% for social in footer.social %}
        <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" title="{{ social.name }}">
          {{ social.name[0] }}
        </a>
        {% endfor %}
      </div>
      {% endif %}
    </div>

  </div>

  <!-- Copyright -->
  <div class="site-footer__meta mono">
    <span>© 2026 DEVOPS MANAUS · CC BY-SA 4.0</span>
    <span>HECHO NA FLORESTA · 03°06′S 60°01′W</span>
  </div>

</footer>

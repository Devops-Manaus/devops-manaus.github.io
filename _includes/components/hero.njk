<section id="home" style="max-width: 1200px; margin: 0 auto; padding: 120px 28px 60px;">

  <div class="mono" style="font-size: 12px; color: var(--ink-3); letter-spacing: 0.5px; margin-bottom: 22px; display: flex; align-items: center; gap: 10px;">
    <span style="display: inline-block; width: 6px; height: 6px; border-radius: 99px; background: var(--accent);"></span>
    MANAUS · AMAZONAS · 03°06′S 60°01′W
  </div>

  <h1 style="font-size: 52px; line-height: 1.05; margin: 0; letter-spacing: -1.2px; max-width: 820px; font-weight: 600;">
    {{ hero.title }}
  </h1>

  {% if hero.subtitle %}
  <p style="font-size: 17px; line-height: 1.55; color: var(--ink-2); max-width: 620px; margin-top: 22px;">
    {{ hero.subtitle }}
  </p>
  {% endif %}

  {% if hero.lema %}
  <p style="font-size: 15px; font-style: italic; color: var(--ink-3); max-width: 620px; margin-top: 12px;">
    {{ hero.lema }}
  </p>
  {% endif %}

  {% if hero.cta %}
  <div style="display: flex; gap: 10px; margin-top: 34px; align-items: center;">
    <a href="{{ hero.cta.href }}" style="background: var(--ink); color: var(--bg); border: 0; border-radius: 8px; padding: 13px 20px; font-size: 14px; font-weight: 500; text-decoration: none; display: inline-block;">
      {{ hero.cta.label }}
    </a>
  </div>
  {% endif %}

</section>

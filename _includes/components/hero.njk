<section id="home" class="hero">

  <div class="hero__eyebrow mono">
    <span></span>
    MANAUS · AMAZONAS · 03°06′S 60°01′W
  </div>

  <h1 class="hero__title">
    {{ hero.title }}
  </h1>

  {% if hero.subtitle %}
  <p class="hero__subtitle">
    {{ hero.subtitle }}
  </p>
  {% endif %}

  {% if hero.lema %}
  <p class="hero__lema">
    {{ hero.lema }}
  </p>
  {% endif %}

  {% if hero.cta %}
  <div class="hero__actions">
    <a href="{{ hero.cta.href }}" class="button button--ink">
      {{ hero.cta.label }}
    </a>
  </div>
  {% endif %}

</section>

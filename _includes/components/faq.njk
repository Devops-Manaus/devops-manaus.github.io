<section style="max-width: 1200px; margin: 0 auto; padding: 70px 28px;">

  <h2 style="font-size: 42px; margin: 0 0 60px 0; font-weight: 600; letter-spacing: -1px;">
    Perguntas frequentes
  </h2>

  <div style="display: flex; flex-direction: column; gap: 16px; max-width: 760px;">
    {% for item in search.pages("type=faq", "order=asc") %}
    <div style="padding: 24px 28px; background: var(--bg-card); border: 1px solid var(--line); border-radius: 12px;">
      <h3 style="font-size: 16px; margin: 0 0 10px 0; font-weight: 600; color: var(--ink);">
        {{ item.question }}
      </h3>
      <p style="font-size: 14px; color: var(--ink-2); line-height: 1.6; margin: 0;">
        {{ item.answer }}
      </p>
    </div>
    {% endfor %}
  </div>

</section>

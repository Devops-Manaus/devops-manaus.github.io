<section id="contact" class="lead">

  <div class="lead__panel">

    {% if lead.title %}
    <h2>
      {{ lead.title }}
    </h2>
    {% endif %}

    {% if lead.description %}
    <p>
      {{ lead.description }}
    </p>
    {% endif %}

    {% if lead.ctas %}
    <div class="lead__actions">
      {% for cta in lead.ctas %}
        {% if cta.variant == "primary" %}
          <a href="{{ cta.href }}" class="button button--light">
            {{ cta.label }}
          </a>
        {% else %}
          <a href="{{ cta.href }}" class="button button--outline-light">
            {{ cta.label }}
          </a>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  </div>

</section>

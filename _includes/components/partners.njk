<section id="partners" class="partners" aria-labelledby="partners-title">
  <div class="partners__heading">
    <p class="partners__eyebrow">Construído em rede</p>
    <h2 id="partners-title">Quem caminha<br />com a gente.</h2>
  </div>

  <div class="partners__carousel" aria-label="Parceiros">
    <div class="partners__track">
      {% for partner in partners.items %}
      <figure class="partner-card">
        <div class="partner-card__image">
          <img src="{{ partner.image }}" alt="Logo de {{ partner.name }}" width="160" height="160" />
        </div>
        <figcaption>{{ partner.name }}</figcaption>
      </figure>
      {% endfor %}
      {% for partner in partners.items %}
      <figure class="partner-card" aria-hidden="true">
        <div class="partner-card__image">
          <img src="{{ partner.image }}" alt="" width="160" height="160" />
        </div>
        <figcaption>{{ partner.name }}</figcaption>
      </figure>
      {% endfor %}
    </div>
  </div>
</section>

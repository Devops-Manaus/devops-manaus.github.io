<section id="contact" class="content-section contact">

  <div class="contact__intro">
    <p>Fale com a gente</p>
    <h2>Uma conversa<br />começa por aqui.</h2>
    <p class="contact__description">Quer propor uma parceria, convidar a comunidade ou tirar uma dúvida? Escreva para a gente.</p>
    <a class="contact__email" href="mailto:devopsmanaus@gmail.com">devopsmanaus@gmail.com</a>
  </div>

  <form class="contact__form" action="mailto:devopsmanaus@gmail.com" method="post" enctype="text/plain">
    <div class="contact__form-fields">
      <label>
        <span>Seu nome</span>
        <input type="text" name="nome" autocomplete="name" required />
      </label>
      <label>
        <span>Seu e-mail</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
    </div>
    <label>
      <span>Como podemos ajudar?</span>
      <textarea name="mensagem" rows="5" required></textarea>
    </label>
    <button type="submit" class="button button--ink">Enviar mensagem</button>
  </form>

</section>

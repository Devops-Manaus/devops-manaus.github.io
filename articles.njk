---
layout: layouts/base.njk
title: Artigos — DevOps Manaus
url: /articles/
---

<section style="max-width: 1100px; margin: 0 auto; padding: 6rem 1.5rem 4rem;">
  <header style="margin-bottom: 3rem;">
    <h1 style="font-size: 2.5rem; margin: 0 0 .5rem;">Artigos</h1>
    <p style="color: #807a6d; margin: 0;">Conteúdos da comunidade DevOps Manaus</p>
  </header>

  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
    {% for post in search.pages("type=article", "date=desc") %}
      <a href="{{ post.url }}" style="display: block; text-decoration: none; color: inherit; background: #ffffff; border: 1px solid #e6e0d4; border-radius: 12px; overflow: hidden; transition: transform .2s;">
        {% if post.image %}
          <img src="{{ post.image }}" alt="{{ post.title }}" style="width: 100%; height: 200px; object-fit: cover; display: block;">
        {% endif %}
        <div style="padding: 1.25rem 1.5rem 1.5rem;">
          <h2 style="font-size: 1.25rem; margin: 0 0 .5rem; line-height: 1.3;">{{ post.title }}</h2>
          {% if post.excerpt %}
            <p style="color: #4a463e; margin: 0 0 .75rem; line-height: 1.5;">{{ post.excerpt }}</p>
          {% endif %}
          {% if post.date %}
            <time style="color: #807a6d; font-size: .85rem;">{{ post.date }}</time>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</section>
